# ─────────────────────────────────────────────────────────────────────────────
# Verdant — Carbon Intelligence Platform · Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.
#
# cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API Key
# Required for AI-powered carbon insights on the /insights page.
# Get a free key at: https://ai.google.dev/
# Without this key, the app gracefully falls back to pre-built insights.
GEMINI_API_KEY=

# Neon / Serverless Postgres connection string.
# Vercel Marketplace Neon integration can inject this automatically.
DATABASE_URL=

# Random 32+ character secret used to sign anonymous session cookies.
SESSION_SECRET=

# App Configuration (optional — defaults shown)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Verdant
