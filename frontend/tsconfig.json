{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "zod": [
        "./node_modules/zod"
      ],
      "@google/genai": [
        "./node_modules/@google/genai"
      ],
      "@neondatabase/serverless": [
        "./node_modules/@neondatabase/serverless"
      ],
      "drizzle-orm": [
        "./node_modules/drizzle-orm"
      ],
      "drizzle-orm/*": [
        "./node_modules/drizzle-orm/*"
      ],
      "next": [
        "./node_modules/next"
      ],
      "next/*": [
        "./node_modules/next/*"
      ],
      "@/backend/*": [
        "./backend/*"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
